{
  "name": "@mintlify/prebuild",
  "type": "module",
  "version": "1.0.1061",
  "description": "Helpful functions for Mintlify's prebuild step",
  "author": "Mintlify, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mintlify/mint",
    "directory": "packages/prebuild"
  },
  "bugs": {
    "url": "https://github.com/mintlify/mint/issues"
  },
  "license": "Elastic-2.0",
  "keywords": [
    "mintlify",
    "mint",
    "prebuild"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc --project tsconfig.build.json",
    "clean:build": "rimraf dist",
    "clean:all": "rimraf node_modules .eslintcache && yarn clean:build",
    "watch": "tsc --project tsconfig.build.json --watch",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "type": "tsc --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@mintlify/common": "1.0.917",
    "@mintlify/openapi-parser": "0.0.8",
    "@mintlify/scraping": "4.0.781",
    "@mintlify/validation": "0.1.715",
    "chalk": "5.3.0",
    "favicons": "7.2.0",
    "front-matter": "4.0.2",
    "fs-extra": "11.1.0",
    "js-yaml": "4.1.1",
    "openapi-types": "12.1.3",
    "sharp": "0.33.5",
    "sharp-ico": "0.1.5",
    "unist-util-visit": "4.1.2",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@mintlify/eslint-config-typescript": "1.0.13",
    "@mintlify/models": "0.0.314",
    "@mintlify/ts-config": "2.0.2",
    "@tsconfig/recommended": "1.0.2",
    "@types/mdast": "4.0.4",
    "@types/node": "18.15.10",
    "@typescript-eslint/parser": "6.9.1",
    "eslint": "8.36.0",
    "oxfmt": "^0.51.0",
    "rimraf": "5.0.1",
    "typescript": "5.5.3",
    "vitest": "2.1.9"
  },
  "gitHead": "c265f4e691e8af85630e4d809c35afb76d3b0770"
}
